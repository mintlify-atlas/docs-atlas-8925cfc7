  "keyFeatures": [
    "Interactive exploration of 8 world wonders with rich visual effects",
    "Historical timeline with events spanning from 3000 BCE to present",
    "Artifact search powered by Metropolitan Museum API",
    "Photo galleries with Unsplash integration",
    "Collectible discovery system with progress tracking",
    "Multi-language support (English and Chinese)",
    "Cross-platform support (iOS, Android, Web, macOS, Windows)",
    "Advanced Flutter animations and custom transitions",
    "Responsive design with portrait and landscape layouts",
    "Google Maps integration for wonder locations"
  ],
  "publicApiSurface": [
    "WondersLogic - Core logic for managing wonder data",
    "AppLogic - Main app controller and bootstrap",
    "TimelineLogic - Historical timeline management",
    "CollectiblesLogic - Collectibles tracking and persistence",
    "ArtifactAPILogic - Metropolitan Museum artifact search",
    "UnsplashLogic - Photo gallery integration",
    "SettingsLogic - User preferences and app configuration",
    "LocaleLogic - Localization and language switching",
    "WonderData - Data model for world wonders",
    "WonderType - Enum for 8 world wonders",
    "AppRouter - GoRouter configuration",
    "ScreenPaths - Route path definitions"
  ]
